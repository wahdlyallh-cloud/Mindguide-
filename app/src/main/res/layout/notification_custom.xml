<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_notification_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:textDirection="rtl">

    <!-- Top Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Right Side: Green dot & App Name -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="يومياتي AI • نشط الآن "
                android:textColor="#2E7D32"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Green dot -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#4CAF50"
                android:textSize="14dp" />
        </LinearLayout>

        <!-- Left Side: Android badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_notification_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إشعار مثبت بالأندرويد"
                android:textColor="#37474F"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Body Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="right"
        android:text="كيف تشعر الآن يا صديقي؟ 😊 اضغط على أي من الاختصارات السريعة أدناه لتدوين مذكراتك أو رصد حالتك المزاجية مباشرة وبمنتهى الخصوصية والأمان."
        android:textColor="#555555"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Horizontal Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="6">

        <!-- Button 1: Camera (صورة) -->
        <LinearLayout
            android:id="@+id/btn_notif_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_camera" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="صورة"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 2: Check (مهمة) -->
        <LinearLayout
            android:id="@+id/btn_notif_check"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_check" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="مهمة"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 3: Consultant (مستشار) -->
        <LinearLayout
            android:id="@+id/btn_notif_consultant"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_consultant" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="مستشار"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 4: Heart (مزاجي) -->
        <LinearLayout
            android:id="@+id/btn_notif_heart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_heart" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="مزاجي"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 5: Mic (تسجيل) -->
        <LinearLayout
            android:id="@+id/btn_notif_mic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_mic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="تسجيل"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Button 6: Pencil (كتابة) -->
        <LinearLayout
            android:id="@+id/btn_notif_pencil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_notification_button_circle"
                android:padding="10dp"
                android:src="@drawable/ic_notif_pencil" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="كتابة"
                android:textColor="#333333"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Footer Row Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE" />

    <!-- Footer Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <!-- Right Side: Lock text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="الخصوصية محمية بقفل PIN 🔒"
            android:textColor="#78909C"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Left Side: Hint text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:text="انقر على أي اختصار لتشغيله في التطبيق"
            android:textColor="#90A4AE"
            android:textSize="11sp" />
    </RelativeLayout>

</LinearLayout>
